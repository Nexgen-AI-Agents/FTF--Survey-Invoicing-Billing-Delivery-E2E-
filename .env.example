# FTF Agentic AI OS — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env — it is gitignored.

# ── Deployment environment ────────────────────────────────────────────────────
# "stage" (default) or "prod". Controls all FTF URLs automatically.
# See code/shared/config/env_profiles.py for what each profile sets.
DEPLOY_ENV=stage

# ── FTF API ───────────────────────────────────────────────────────────────────
# Leave blank to use env_profiles.py defaults (recommended).
# Only set if you need to override the profile URL for a specific env.
FTF_API_BASE_URL=
FTF_API_KEY=your_ftf_api_key_here
FTF_ORDER_URL=
FTF_SITE_BASE_URL=
FTF_PAY_HASH_KEY=your_fernet_key_here

# ── MySQL (FTF Stage DB — AWS RDS) ────────────────────────────────────────────
MYSQL_HOST=your-rds-host.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=nexgen_ftf_db

# ── Azure AD App (Graph API — Files.ReadWrite.All) ────────────────────────────
AZURE_TENANT_ID=your_tenant_id
AZURE_APP_ID=your_app_id
AZURE_CLIENT_SECRET=your_client_secret

# ── OneDrive approval spreadsheet ─────────────────────────────────────────────
# Sharing link to FTF-Invoicing Agent.xlsx on nesa@nexgenlogix.com's OneDrive.
# Get this by right-clicking the file in OneDrive and choosing "Copy link".
ONEDRIVE_SHARE_URL=https://nexgensurveying-my.sharepoint.com/:x:/g/personal/nesa_nexgenlogix_com/...
ONEDRIVE_FILE_USER=nesa@nexgenlogix.com

# ── SMTP (invoice + notification email delivery) ──────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=nesa@nexgenlogix.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=nesa@nexgenlogix.com

# ── Notifications & Safety ────────────────────────────────────────────────────
NOTIFICATION_FROM_EMAIL=pchandra@nexgen.enterprises
NOTIFICATION_TO_EMAILS=rt@ryantisko.com,robert_e@nexgenlogix.com
# Format: "name:email,name:email"
APPROVED_SENDERS=robert:robert_e@nexgenlogix.com,ryan:rt@ryantisko.com,prateek:pchandra@nexgen.enterprises,nesa:nesa@nexgenlogix.com
GOOGLE_REVIEW_URL=https://share.google/your-review-link
# When set, ALL invoice emails are redirected to this address (no client ever receives email)
EMAIL_OVERRIDE_ALL=pchandra@nexgen.enterprises

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Google Maps (aerial image fetch for A2) ───────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── FTF Books (AR report download — session-cookie auth) ─────────────────────
FTF_BOOKS_BASE_URL=
FTF_BOOKS_USER=your_books_username
FTF_BOOKS_PASSWORD=your_books_password

# ── IMAP (nesa@nexgenlogix.com inbox — A2 email search) ─────────────────────
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_USER=nesa@nexgenlogix.com
IMAP_PASSWORD=your_imap_password

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
