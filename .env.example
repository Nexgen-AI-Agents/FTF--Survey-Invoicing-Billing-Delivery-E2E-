# FTF Agentic AI OS — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env — it is gitignored.
# All 10 variables are required unless marked optional.

# ── FTF API ─────────────────────────────────────────────────────────────────
# Base URL for FTF CRM + Books + Pricing API
FTF_API_BASE_URL=https://stage.fieldtofinish.jobs/ftf-ai-api/v1

# Secret key for FTF API authentication
FTF_API_KEY=your_ftf_api_key_here

# ── Anthropic Claude API ─────────────────────────────────────────────────────
# Claude API key — from Anthropic console
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── PostgreSQL Database ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ftf_agentic_ai
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ── Microsoft Teams ──────────────────────────────────────────────────────────
# Incoming webhook URL for the MS Teams alert channel
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/your-webhook-path

# ── FTF Books module (session-cookie auth) ──────────────────────────────────
# Separate from REST API — used by skills/ftf_ar_report/scripts/build_ar_report.py
FTF_BOOKS_BASE_URL=https://stage.fieldtofinish.jobs
FTF_BOOKS_USER=your_books_username
FTF_BOOKS_PASSWORD=your_books_password

# ── Logging (optional) ───────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
